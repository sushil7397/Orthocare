# Copy to .env and fill in. For local dev you can leave DATABASE_URL blank to use SQLite.
DATABASE_URL=postgresql+psycopg2://ortho:ortho@localhost:5432/orthocare
REDIS_URL=redis://localhost:6379/0
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALG=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
# Slot hold (minutes) for tentative bookings
SLOT_HOLD_MINUTES=10
